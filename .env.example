# Environment Variables — Inkrypt
# Copy this to .env in the project root. Never commit .env to version control.

# ── Frontend ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=Inkrypt
VITE_USE_MOCK_API=false

# ── Backend ────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_BEFORE_DEPLOYING

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/inkrypt

# ── Email / OTP ───────────────────────────────────────────────────────────
# Leave blank to use console fallback in development (OTP will be logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@inkrypt.app
APP_NAME=Inkrypt
APP_DOMAIN=inkrypt.app
OTP_EXPIRY_MINUTES=10

# ── Tauri Desktop (auto-set, do not edit) ─────────────────────────────────
# TAURI_BUILD_TARGET=x86_64-pc-windows-msvc
