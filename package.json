{
  "name": "inkrypt-monorepo",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Sachin-S543",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sachin-S543/Diary.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev --workspace=@inkrypt/server\" \"npm run dev --workspace=@inkrypt/frontend\"",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspace=@inkrypt/frontend",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules dist"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.0.0",
    "eslint": "^8.0.0",
    "husky": "^8.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@tauri-apps/cli": "^2.10.1"
  }
}
